# =============================================================================
# SkillSync Server Configuration
# =============================================================================

# Environment
NODE_ENV=development

# Server
PORT=3000
API_PREFIX=api

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-secure-database-password
DB_NAME=skillsync_db
DB_SSL=false

# Reverse Proxy Configuration
# Set to true if behind Nginx, CloudFlare, AWS ALB, etc.
TRUST_PROXY=true

# =============================================================================
# CORS Configuration - WHITELIST YOUR FRONTEND DOMAINS
# =============================================================================

# Allowed origins (comma-separated list)
# Format examples:
#   Single domain: https://yourdomain.com
#   Multiple domains: https://yourdomain.com,https://api.yourdomain.com,https://app.yourdomain.com
#   With wildcards: https://*.staging.yourdomain.com (for all staging subdomains)
#   Multiple patterns: https://yourdomain.com,https://*.staging.yourdomain.com
# In development mode: localhost:3000-5173 are automatically allowed
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# HTTP methods allowed by CORS requests
# Default: GET,POST,PUT,PATCH,DELETE
# Valid methods: GET, POST, PUT, PATCH, DELETE, OPTIONS, HEAD
CORS_METHODS=GET,POST,PUT,PATCH,DELETE

# Allow credentials (cookies and authorization headers) in CORS requests
# Set to false if frontend doesn't use credentials (JWT in headers is fine)
# Default: true
CORS_CREDENTIALS=true

# [OPTIONAL] Custom allowed headers sent by clients
# Default: Content-Type,Authorization,Accept,X-CSRF-Token,X-Requested-With,User-Agent
# CORS_ALLOWED_HEADERS=Content-Type,Authorization,Accept,X-CSRF-Token,X-Requested-With,User-Agent

# [OPTIONAL] Custom exposed headers sent by server
# Default: X-Total-Count,X-Page-Count,X-Request-Id,Content-Length
# CORS_EXPOSED_HEADERS=X-Total-Count,X-Page-Count,X-Request-Id,Content-Length

# CORS preflight cache duration in seconds
# Reduces OPTIONS requests by caching preflight responses
# Default: 600 (10 minutes)
CORS_PREFLIGHT_MAX_AGE=600

# =============================================================================
# Cookie Security Configuration
# =============================================================================

# Secure: Only send cookies over HTTPS (auto-enabled in production)
COOKIE_SECURE=true

# HttpOnly: Prevent JavaScript access to cookies (prevent XSS attacks)
COOKIE_HTTP_ONLY=true

# SameSite: CSRF protection (strict recommended)
# Options: strict, lax, none
# none requires Secure=true and HTTPS
COOKIE_SAME_SITE=strict

# [OPTIONAL] Cookie domain (for subdomain sharing)
# COOKIE_DOMAIN=.yourdomain.com

# Cookie expiration in milliseconds (default: 1 hour = 3600000ms)
COOKIE_MAX_AGE=3600000

# =============================================================================
# Redis Configuration
# =============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-secure-redis-password
REDIS_DB=0
REDIS_KEY_PREFIX=skillsync
REDIS_CONNECT_TIMEOUT=10000

# =============================================================================
# Cloudinary Configuration (Image Hosting)
# =============================================================================

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_secret

# =============================================================================
# Rate Limiting Configuration
# =============================================================================

RATE_LIMIT_ENABLED=true

# Global rate limiting (applies to all requests)
# Production default: 50 req/min (stricter)
# Development default: 100 req/min
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
RATE_LIMIT_GLOBAL_MAX=100

# Per-IP rate limiting (unauthenticated users)
# Production default: 10 req/min (very strict)
RATE_LIMIT_PER_IP_WINDOW_MS=60000
RATE_LIMIT_PER_IP_MAX=10

# Per-wallet rate limiting
RATE_LIMIT_PER_WALLET_WINDOW_MS=60000
RATE_LIMIT_PER_WALLET_MAX=50

# Per-user rate limiting (authenticated users)
# Production default: 50 req/min (strict)
RATE_LIMIT_PER_USER_WINDOW_MS=60000
RATE_LIMIT_PER_USER_MAX=50

# Predefined rate limits
RATE_LIMIT_STRICT_MAX=10
RATE_LIMIT_RELAXED_MAX=1000

# Paths to exempt from rate limiting (comma-separated)
RATE_LIMIT_EXEMPT_PATHS=/health,/health/redis

# =============================================================================
# JWT Configuration - REQUIRED IN PRODUCTION (min 32 characters)
# =============================================================================

# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-32-characters-long
JWT_EXPIRES_IN=1h

# =============================================================================
# Mail Configuration (SMTP)
# =============================================================================

MAIL_SENDER=noreply@yourdomain.com
MAIL_SUBJECT_PREFIX=[SkillSync]
MAIL_APP_NAME=SkillSync
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_SECURE=false

# One-Time Password (OTP) Configuration
OTP_TTL_MINUTES=10
OTP_SUBJECT=Your One-Time Password (OTP)

# =============================================================================
# Swagger API Documentation Configuration
# =============================================================================

# Enable Swagger UI (NOT RECOMMENDED in production)
SWAGGER_ENABLED=false

# =============================================================================
# Feature Flags
# =============================================================================

FEATURE_ENABLE_SWAGGER=true
FEATURE_ENABLE_CACHE=true
FEATURE_ENABLE_RATE_LIMITING=true
FEATURE_ENABLE_LOGGING=true

# =============================================================================
# Seed Configuration
# =============================================================================

# Set to 'true' to disable automatic seeding on startup
DISABLE_SEED=false

# Admin wallet address for the default admin user
# This should be a valid Stellar wallet address
DEFAULT_ADMIN_WALLET=0x742d35Cc6634C0532925a3b844Bc2e7c6A9A8B0F

# =============================================================================
# Logging Configuration
# =============================================================================

LOG_LEVEL=log
LOG_FORMAT=simple

# =============================================================================
# Graceful Shutdown Configuration
# =============================================================================

# Shutdown timeout in milliseconds (default: 30000 = 30 seconds)
# Time allowed for in-flight requests to complete before force shutdown
SHUTDOWN_TIMEOUT=30000

# =============================================================================
# Database Backup Configuration
# =============================================================================

# Backup storage directory (default: ./backups)
BACKUP_DIRECTORY=./backups

# WAL archive directory (default: ./wal_archive)
WAL_ARCHIVE_DIRECTORY=./wal_archive

# Backup retention period in days (default: 30)
BACKUP_RETENTION_DAYS=30

# Enable backup encryption (AES-256-GCM)
BACKUP_ENCRYPTION_ENABLED=true

# Encryption key for backup encryption (min 32 characters)
# Generate with: openssl rand -base64 32
BACKUP_ENCRYPTION_KEY=your-encryption-key-min-32-characters

# AWS S3 Configuration for offsite backup storage
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=your-aws-access-key
BACKUP_S3_SECRET_KEY=your-aws-secret-key

# Backup alert email (for failure notifications)
BACKUP_ALERT_EMAIL=admin@yourdomain.com
